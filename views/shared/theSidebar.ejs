<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Side bar</title>
</head>

<body>
    <!-- views/shared/theSidebar.ejs -->
    <aside class="w-56 min-w-56 h-screen bg-slate-900 flex flex-col">

        <!-- Logo -->
        <div class="px-4 py-5 border-b border-slate-700/50">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-emerald-500 rounded-lg flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path
                            d="M19 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2zm-7 14v-4H8v-2h4V7h2v4h4v2h-4v4h-2z" />
                    </svg>
                </div>
                <div>
                    <p class="text-white text-sm font-medium leading-none">PharmaOS</p>
                    <p class="text-slate-500 text-xs mt-1">Management System</p>
                </div>
            </div>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 px-3 py-4 overflow-y-auto space-y-1">

            <!-- Main Section -->
            <p class="text-slate-500 text-xs font-medium uppercase tracking-wider px-2 mb-2">Main</p>

            <a href="/dashboard" class="flex items-center gap-3 px-3 py-2 rounded-lg
      <%= currentPath === '/dashboard' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800/60 hover:text-slate-200' %>
      transition-colors duration-150 group">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2"
                    viewBox="0 0 24 24">
                    <rect x="3" y="3" width="7" height="7" />
                    <rect x="14" y="3" width="7" height="7" />
                    <rect x="14" y="14" width="7" height="7" />
                    <rect x="3" y="14" width="7" height="7" />
                </svg>
                <span class="text-sm">Dashboard</span>
            </a>

            <a href="/inventory" class="flex items-center gap-3 px-3 py-2 rounded-lg
      <%= currentPath === '/inventory' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800/60 hover:text-slate-200' %>
      transition-colors duration-150">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2"
                    viewBox="0 0 24 24">
                    <path d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z" />
                    <path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16" />
                </svg>
                <span class="text-sm">Inventory</span>
                <span class="ml-auto bg-emerald-500 text-white text-xs font-medium px-2 py-0.5 rounded-full">12</span>
            </a>

            <a href="/prescriptions" class="flex items-center gap-3 px-3 py-2 rounded-lg
      <%= currentPath === '/prescriptions' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800/60 hover:text-slate-200' %>
      transition-colors duration-150">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2"
                    viewBox="0 0 24 24">
                    <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" />
                    <rect x="9" y="3" width="6" height="4" rx="2" />
                    <path d="M9 12h6M9 16h4" />
                </svg>
                <span class="text-sm">Prescriptions</span>
            </a>

            <a href="/sales" class="flex items-center gap-3 px-3 py-2 rounded-lg
      <%= currentPath === '/sales' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800/60 hover:text-slate-200' %>
      transition-colors duration-150">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2"
                    viewBox="0 0 24 24">
                    <circle cx="9" cy="21" r="1" />
                    <circle cx="20" cy="21" r="1" />
                    <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6" />
                </svg>
                <span class="text-sm">Sales</span>
            </a>

            <!-- Divider -->
            <div class="border-t border-slate-700/50 my-3"></div>

            <!-- Management Section -->
            <p class="text-slate-500 text-xs font-medium uppercase tracking-wider px-2 mb-2">Management</p>

            <a href="/patients" class="flex items-center gap-3 px-3 py-2 rounded-lg
      <%= currentPath === '/patients' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800/60 hover:text-slate-200' %>
      transition-colors duration-150">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2"
                    viewBox="0 0 24 24">
                    <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" />
                </svg>
                <span class="text-sm">Patients</span>
            </a>

            <a href="/suppliers" class="flex items-center gap-3 px-3 py-2 rounded-lg
      <%= currentPath === '/suppliers' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800/60 hover:text-slate-200' %>
      transition-colors duration-150">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2"
                    viewBox="0 0 24 24">
                    <rect x="1" y="3" width="15" height="13" rx="1" />
                    <path
                        d="M16 8h4l3 3v5h-7V8zM5.5 21a1.5 1.5 0 100-3 1.5 1.5 0 000 3zM18.5 21a1.5 1.5 0 100-3 1.5 1.5 0 000 3z" />
                </svg>
                <span class="text-sm">Suppliers</span>
            </a>

            <a href="/reports" class="flex items-center gap-3 px-3 py-2 rounded-lg
      <%= currentPath === '/reports' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800/60 hover:text-slate-200' %>
      transition-colors duration-150">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2"
                    viewBox="0 0 24 24">
                    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
                    <path d="M14 2v6h6M16 13H8M16 17H8M10 9H8" />
                </svg>
                <span class="text-sm">Reports</span>
            </a>

            <!-- Settings Section -->
            <div class="border-t border-slate-700/50 my-3"></div>

            <a href="/settings" class="flex items-center gap-3 px-3 py-2 rounded-lg
      <%= currentPath === '/settings' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800/60 hover:text-slate-200' %>
      transition-colors duration-150">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2"
                    viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="3" />
                    <path
                        d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" />
                </svg>
                <span class="text-sm">Settings</span>
            </a>

        </nav>

        <!-- User Profile Footer -->
        <div class="px-3 py-4 border-t border-slate-700/50">
            <div
                class="flex items-center gap-3 px-2 py-2 rounded-lg hover:bg-slate-800/60 cursor-pointer transition-colors">
                <div class="w-8 h-8 rounded-full bg-emerald-500 flex items-center justify-center flex-shrink-0">
                    <span class="text-white text-xs font-medium">AK</span>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-slate-200 text-sm font-medium truncate">Admin Khan</p>
                    <p class="text-slate-500 text-xs truncate">Super Admin</p>
                </div>
                <a href="/logout">
                    <svg class="w-4 h-4 text-slate-500 hover:text-slate-300 flex-shrink-0" fill="none"
                        stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9" />
                    </svg>
                </a>
            </div>
        </div>

    </aside>
</body>

</html>